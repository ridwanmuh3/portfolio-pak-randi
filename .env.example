# =============================================================================
# Copy this file to .env and fill in ALL values before running docker compose.
# NEVER commit .env — it contains secrets.
# =============================================================================

# --- Public domain -----------------------------------------------------------
# The URL your visitors use to reach the site (no trailing slash).
# Used by nginx, Strapi, and baked into the Next.js bundle for media URLs.
SITE_URL=https://yourdomain.com

# Public-facing URL for Strapi media assets.
# In production this equals SITE_URL because nginx proxies /uploads/ from Strapi.
NEXT_PUBLIC_STRAPI_URL=https://yourdomain.com

# Strapi's own public URL (used for admin panel redirects, email links, etc.)
STRAPI_PUBLIC_URL=https://yourdomain.com

# --- Frontend API token (read-only) ------------------------------------------
# Generate in Strapi admin: Settings → API Tokens → Create (Read-only, Unlimited)
STRAPI_API_TOKEN=

# --- CORS --------------------------------------------------------------------
# Must match your public domain.
ALLOWED_ORIGINS=https://yourdomain.com

# --- Strapi cryptographic secrets --------------------------------------------
# Generate each with: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_KEYS=change_me_key1,change_me_key2
API_TOKEN_SALT=change_me
ADMIN_JWT_SECRET=change_me
TRANSFER_TOKEN_SALT=change_me
JWT_SECRET=change_me
ENCRYPTION_KEY=change_me_32chars

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=change_me_strong_password
# DATABASE_CLIENT=postgres  # default: postgres — only set if changing DB engine

# --- smartqr app (Nuxt / Supabase) -------------------------------------------
SMARTQR_PUBLIC_URL=https://randirizal.my.id/projects/smartqr
SMARTQR_SUPABASE_URL=
SMARTQR_SUPABASE_KEY=
SMARTQR_SUPABASE_SERVICE_KEY=
# Set to "true" when nginx (or any trusted proxy) forwards X-Forwarded-For headers
NUXT_TRUSTED_PROXY=true
# How long (seconds) a verify token stays valid before expiring
NUXT_VERIFY_TOKEN_TTL_SEC=90
