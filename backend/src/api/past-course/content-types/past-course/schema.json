{
  "kind": "collectionType",
  "collectionName": "past_courses",
  "info": {
    "singularName": "past-course",
    "pluralName": "past-courses",
    "displayName": "Past Course",
    "description": "Previously taught courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginsOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "maxLength": 20
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "level": {
      "type": "enumeration",
      "enum": ["Undergraduate", "Graduate"],
      "required": true
    },
    "years": {
      "type": "string",
      "required": true,
      "maxLength": 50
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
